{
  "name": "murmur",
  "version": "1.0.0",
  "description": "Murmur - 基于FunASR和可配置AI模型的中文优化语音转文字应用",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "prestart": "npm run build:preload",
    "predev": "npx electron-rebuild && npm run build:preload",
    "dev": "concurrently -k -r \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:main": "cross-env NODE_ENV=development electron --require tsx/cjs . --dev",
    "build:main": "esbuild main.js --bundle --platform=node --format=cjs --external:electron --external:better-sqlite3 --outfile=dist-main/main.js",
    "dev:renderer": "cd src && vite",
    "build:preload": "esbuild preload.js --bundle --platform=node --format=cjs --external:electron --outfile=dist-preload/preload.js",
    "build": "npm run build:preload && cd src && vite build && cd .. && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "build:renderer": "cd src && vite build",
    "prepare:python": "pip install funasr modelscope torch torchaudio librosa numpy && python download_models.py",
    "prepare:python:uv": "uv sync && uv run python download_models.py",
    "prepare:python:embedded": "node scripts/prepare-embedded-python.js",
    "prepare:python:info": "node scripts/prepare-embedded-python.js --info",
    "test:python": "node scripts/test-embedded-python.js",
    "test:python:info": "node scripts/test-embedded-python.js --info",
    "prebuild:mac": "npm run prepare:python:embedded && npm run build:preload && npm run build:renderer",
    "build:mac": "electron-builder --mac",
    "prebuild:win": "npm run prepare:python:embedded && npm run build:preload && npm run build:renderer",
    "build:win": "electron-builder --win",
    "prebuild:linux": "npm run prepare:python:embedded && npm run build:preload && npm run build:renderer",
    "build:linux": "electron-builder --linux",
    "pack": "npm run build:preload && npm run build:renderer && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "npm run prepare:python:embedded && npm run build:preload && npm run build:renderer && electron-builder",
    "test": "pnpm rebuild better-sqlite3 && vitest run",
    "test:coverage": "pnpm rebuild better-sqlite3 && vitest run --coverage",
    "test:watch": "pnpm rebuild better-sqlite3 && vitest",
    "test:e2e": "playwright-core test --config playwright.config.js",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"*.{js,json,md,yml}\" \"src/**/*.{js,jsx,ts,tsx,css}\" \"tests/**/*.{js,ts}\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"*.{js,json,md,yml}\" \"src/**/*.{js,jsx,ts,tsx,css}\" \"tests/**/*.{js,ts}\" \"scripts/**/*.js\"",
    "license:check": "license-checker --failOn \"GPL-*;AGPL-*\" --excludePrivatePackages",
    "ci:check": "node scripts/ci-check.js",
    "ci:fix": "node scripts/ci-check.js --fix",
    "preview": "cd src && vite preview",
    "clean": "node cleanup.js && rm -rf python",
    "prepare": "husky"
  },
  "keywords": [
    "speech-to-text",
    "funasr",
    "voice-input",
    "chinese",
    "electron",
    "desktop-app",
    "ai",
    "llm",
    "dictation",
    "murmur"
  ],
  "author": {
    "name": "yan5xu",
    "email": "lueco.x@gmail.com"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@electron/notarize": "^3.0.1",
    "@eslint/js": "^9.25.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/vite": "^4.1.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cross-env": "^10.0.0",
    "electron": "36.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "license-checker": "^25.0.1",
    "lint-staged": "^17.0.5",
    "node-gyp": "^11.4.2",
    "playwright-core": "^1.60.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.3.5",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "axios": "^1.6.0",
    "better-sqlite3": "11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.4",
    "i18next": "^26.2.0",
    "lucide-react": "^0.518.0",
    "mime-types": "^3.0.1",
    "next-themes": "^0.4.6",
    "osascript": "^1.0.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "shadcn-ui": "^0.9.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tar": "^7.4.3",
    "tw-animate-css": "^1.3.4",
    "unzipper": "^0.12.3"
  },
  "build": {
    "appId": "com.murmur.app",
    "productName": "Murmur",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "dist-preload/preload.js",
      "funasr_server.py",
      "download_models.py",
      "package.json",
      "LICENSE",
      "NOTICE",
      "THIRD-PARTY-LICENSES",
      "python/**/*",
      "node_modules/**/*",
      "src/dist/**/*",
      "src/helpers/**/*",
      "src/utils/**/*",
      "assets/**/*",
      "!node_modules/.cache/**/*",
      "!src/node_modules/**/*",
      "!python/**/*.pyc",
      "!python/**/__pycache__/**/*"
    ],
    "asarUnpack": [
      "funasr_server.py",
      "download_models.py",
      "python/**/*",
      "node_modules/**/*better-sqlite3*/**/*",
      "node_modules/**/*bindings*/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Office"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TeFuirnever/Murmur.git"
  },
  "homepage": "https://github.com/TeFuirnever/Murmur",
  "bugs": {
    "url": "https://github.com/TeFuirnever/Murmur/issues"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,css}": [
      "prettier --write"
    ]
  }
}
